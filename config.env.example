# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit it.
# CLOUD_PASS is NOT here — pass it as an env var or from AAP vault at runtime.

# ── On-prem cluster (c103) ────────────────────────────────────────────────────
ONPREM_KC=/root/kubeconfig-c103
ONPREM_SC=democratic-csi-nfs
ONPREM_SNAPCLASS=democratic-csi-nfs-snapclass

# ── Cloud cluster (update when cluster is replaced) ───────────────────────────
CLOUD_API=https://api.cluster-rd8bp.dynamic.redhatworkshops.io:6443
CLOUD_USER=admin
CLOUD_SC=ocs-external-storagecluster-ceph-rbd

# ── Shared ────────────────────────────────────────────────────────────────────
NAMESPACE=vmtocloud
SYNC_SCHEDULE=*/30 * * * *

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_REPO=https://github.com/ansonmez/gitops-vm-dr.git
GIT_BRANCH=main

# ── ArgoCD (on snomgm) ────────────────────────────────────────────────────────
ARGOCD_SERVER=openshift-gitops-server-openshift-gitops.apps.<snomgm-domain>
